/dts-v1/;
#include "zynq-7000.dtsi"
#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>

/ {
	model = "Ebang EBAZ4205";
	compatible = "ebang,ebaz4205", "xlnx,zynq-7000";

	interrupt-parent = <&intc>;

	aliases {
		ethernet0 = &gem0;
		serial0 = &uart1;
		serial1 = &uart0;
		mmc0 = &sdhci0;
		spi0 = &spi0;
		smcc = &smcc;
		nfc0 = &nfc0;
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x10000000>;
	};

	chosen {
		bootargs = "console=ttyPS1,115200 console=ttyPS0,115200 root=/dev/mmcblk0p2 rootfstype=ext4 rootwait rw";
		stdout-path = "serial0:115200n8";
	};

	leds {
		compatible = "gpio-leds";

		heartbeat: led0 {
			label = "led0:green";
			gpios = <&gpio0 54 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "heartbeat";
		};

		led1 {
			label = "led0:red";
			gpios = <&gpio0 55 GPIO_ACTIVE_LOW>;
			linux,default-state = "off";
		};

		led2 {
			label = "led1:aux0";
			gpios = <&gpio0 56 GPIO_ACTIVE_HIGH>;
			linux,default-state = "off";
		};

		led3 {
			label = "led1:aux1";
			gpios = <&gpio0 57 GPIO_ACTIVE_HIGH>;
			linux,default-state = "off";
		};

		led4 {
			label = "led1:aux2";
			gpios = <&gpio0 58 GPIO_ACTIVE_HIGH>;
			linux,default-state = "off";
		};
	};

	keys {
		compatible = "gpio-keys";

		restart_key: restart {
			label = "key0:restart";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
		};

		key0 {
			label = "key1:aux0";
			linux,code = <KEY_LEFT>;
			gpios = <&gpio0 59 GPIO_ACTIVE_LOW>;
		};

		key1 {
			label = "key1:aux1";
			linux,code = <KEY_DOWN>;
			gpios = <&gpio0 60 GPIO_ACTIVE_LOW>;
		};

		key2 {
			label = "key1:aux2";
			linux,code = <KEY_ENTER>;
			gpios = <&gpio0 61 GPIO_ACTIVE_LOW>;
		};

		key3 {
			label = "key1:aux3";
			linux,code = <KEY_RIGHT>;
			gpios = <&gpio0 62 GPIO_ACTIVE_LOW>;
		};

		key4 {
			label = "key1:aux4";
			linux,code = <KEY_UP>;
			gpios = <&gpio0 63 GPIO_ACTIVE_LOW>;
		};
	};

	beeper: beeper {
		compatible = "pwm-beeper";
		pwms = <&ttc0 0 370370 0>; /* 2.7 kHz, normal polarity */
	};

	ext_clk_50m: ext_clk_50m {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <50000000>; /* 50 MHz */
	};
};

&ttc0 {
	#pwm-cells = <3>;
};

&clkc {
	ps-clk-frequency = <33333333>;
	fclk-enable = <0xf>;
};

&gem0 {
	status = "okay";
	phy-mode = "rgmii-id";
	phy-handle = <&ethernet_phy>;

	ethernet_phy: ethernet-phy@0 {
		reg = <0>;
	};
};

&sdhci0 {
	status = "okay";
	u-boot,dm-pre-reloc;
};

&gpio0 {
	status = "okay";
};

&spi0 {
	status = "okay";

	st7789v@0 {
		compatible = "sitronix,st7789v";
		reg = <0>;
		buswidth = <8>;
		spi-max-frequency = <32000000>;
		spi-cpol;
		spi-cpha;
		/* control pins */
		reset-gpios = <&gpio0 64 GPIO_ACTIVE_LOW>;
		dc-gpios = <&gpio0 65 GPIO_ACTIVE_HIGH>;
        led-gpios = <&gpio0 66 GPIO_ACTIVE_HIGH>;
		/* optional: rotation, init data via bindings */
		width = <240>;
		height = <240>;
		rotation = <180>; /* can be 0 / 90 / 180 / 270 */
	};
};

&uart0 {
	status = "okay";
	u-boot,dm-pre-reloc;
};

&uart1 {
	status = "okay";
	u-boot,dm-pre-reloc;
};

&smcc {
	status = "okay";
};

&nfc0 {
	status = "okay";

	#address-cells = <1>;
	#size-cells = <0>;

	nand@0 {
		reg = <0>;

		nand-bus-width = <8>;
		nand-ecc-mode = "hw";

		#address-cells = <0x1>;
		#size-cells = <0x1>;

		/* partitions are optional */
//		partition@nand-data {
//			label = "nand-data";
//			reg = <0x00000000 0x08000000>;
//		};
	};
};

/ {
	amba: axi {
		compatible = "simple-bus";
		#address-cells = <0x1>;
		#size-cells = <0x1>;
		ranges;

		hdmi_sink_dma: dma@7c420000 {
			compatible = "adi,axi-dmac-1.00.a";
			reg = <0x7c420000 0x10000>;
			#dma-cells = <1>;
			interrupts = <0 56 IRQ_TYPE_LEVEL_HIGH>;
			clocks = <&clkc 15>;

			adi,channels {
				#size-cells = <0>;
				#address-cells = <1>;

				dma-channel@0 {
					reg = <0>;
					adi,source-bus-width = <64>;
					adi,source-bus-type = <0>;
					adi,destination-bus-width = <64>;
					adi,destination-bus-type = <1>;
				};
			};
		};

		mwipcore0: mwipcore@0 {
			compatible = "mathworks,mwipcore-v3.00";
			#address-cells = <1>;
			#size-cells = <0>;

			stream-channel@0 {
				reg = <0x0>;
				#address-cells = <1>;
				#size-cells = <0>;
				compatible = "mathworks,axi4stream-mm2s-channel-v1.00";
				dmas = <&hdmi_sink_dma 0>;
				dma-names = "hdmi_sink";
				mathworks,dev-name = "hdmi_sink";

				data-channel@0 {
					reg = <0x0>;
					compatible = "mathworks,iio-data-channel-v1.00";
					mathworks,data-format = "u8/8>>0";
				};
			};
		};
	};
};
