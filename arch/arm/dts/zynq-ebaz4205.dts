/dts-v1/;
#include "zynq-7000.dtsi"
#include <dt-bindings/input/input.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>

/ {
	model = "Ebang EBAZ4205";
	compatible = "ebang,ebaz4205", "xlnx,zynq-7000";

	aliases {
		ethernet0 = &gem0;
		serial0 = &uart1;
		serial1 = &uart0;
		mmc0 = &sdhci0;
	};

	memory@0 {
		device_type = "memory";
		reg = <0x0 0x10000000>;
	};

	chosen {
		bootargs = "console=ttyPS1,115200 console=ttyPS0,115200 root=/dev/mmcblk0p2 rootfstype=ext4 rootwait rw";
		stdout-path = "serial0:115200n8";
	};

	leds {
		compatible = "gpio-leds";

		heartbeat: led0 {
			label = "led0:green";
			gpios = <&gpio0 54 GPIO_ACTIVE_LOW>;
			linux,default-trigger = "heartbeat";
		};

		led1 {
			label = "led0:red";
			gpios = <&gpio0 55 GPIO_ACTIVE_LOW>;
			linux,default-state = "off";
		};

		led2 {
			label = "led1:aux0";
			gpios = <&gpio0 56 GPIO_ACTIVE_HIGH>;
			linux,default-state = "off";
		};

		led3 {
			label = "led1:aux1";
			gpios = <&gpio0 57 GPIO_ACTIVE_HIGH>;
			linux,default-state = "off";
		};

		led4 {
			label = "led1:aux2";
			gpios = <&gpio0 58 GPIO_ACTIVE_HIGH>;
			linux,default-state = "off";
		};
	};

	keys {
		compatible = "gpio-keys";

		restart_key: restart {
			label = "key0:restart";
			linux,code = <KEY_RESTART>;
			gpios = <&gpio0 20 GPIO_ACTIVE_HIGH>;
		};

		key0 {
			label = "key1:aux0";
			linux,code = <KEY_LEFT>;
			gpios = <&gpio0 59 GPIO_ACTIVE_LOW>;
		};

		key1 {
			label = "key1:aux1";
			linux,code = <KEY_DOWN>;
			gpios = <&gpio0 60 GPIO_ACTIVE_LOW>;
		};

		key2 {
			label = "key1:aux2";
			linux,code = <KEY_ENTER>;
			gpios = <&gpio0 61 GPIO_ACTIVE_LOW>;
		};

		key3 {
			label = "key1:aux3";
			linux,code = <KEY_RIGHT>;
			gpios = <&gpio0 62 GPIO_ACTIVE_LOW>;
		};

		key4 {
			label = "key1:aux4";
			linux,code = <KEY_UP>;
			gpios = <&gpio0 63 GPIO_ACTIVE_LOW>;
		};
	};

	beeper {
		compatible = "pwm-beeper";
		pwms = <&ttc0 0 370370 0>; /* 2.7 kHz, normal polarity */
	};

	ext_clk_50m: ext_clk_50m {
		compatible = "fixed-clock";
		#clock-cells = <0>;
		clock-frequency = <50000000>; /* 50 MHz */
	};
};

&ttc0 {
	#pwm-cells = <3>;
};

&clkc {
	ps-clk-frequency = <33333333>;
	fclk-enable = <0xf>;
};

&gem0 {
	status = "okay";
	phy-mode = "rgmii-id";
	phy-handle = <&ethernet_phy>;

	ethernet_phy: ethernet-phy@0 {
		reg = <0>;
	};
};

&sdhci0 {
	status = "okay";
	u-boot,dm-pre-reloc;
};

&gpio0 {
	status = "okay";
};

&uart0 {
	status = "okay";
	u-boot,dm-pre-reloc;
};

&uart1 {
	status = "okay";
	u-boot,dm-pre-reloc;
};
